# Copy to .env.local and fill in local-only values for your workstation.

LOCAL_CLUSTER_START="./scripts/start-local-cluster.sh"
LOCAL_CLUSTER_STOP="./scripts/stop-local-cluster.sh"

# Optional local-only telemetry gates.
OBSERVABILITY_ENABLED=1
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:10428/insert/opentelemetry/v1/traces
